{
  "name": "@contentrain/skills",
  "version": "0.2.1",
  "license": "MIT",
  "description": "AI agent skills for Contentrain — workflow procedures, framework integration guides",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Contentrain/ai.git",
    "directory": "packages/skills"
  },
  "homepage": "https://ai.contentrain.io/packages/rules",
  "bugs": {
    "url": "https://github.com/Contentrain/ai/issues"
  },
  "keywords": [
    "contentrain",
    "ai",
    "skills",
    "mcp",
    "workflow",
    "vue",
    "react",
    "nuxt",
    "nextjs",
    "astro",
    "sveltekit",
    "expo",
    "react-native",
    "nodejs"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./skills/*": "./skills/*",
    "./workflows/*": "./workflows/*",
    "./frameworks/*": "./frameworks/*"
  },
  "files": [
    "dist",
    "skills",
    "workflows",
    "frameworks"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
