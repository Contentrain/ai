{
  "name": "@contentrain/rules",
  "version": "0.1.0",
  "license": "MIT",
  "description": "AI agent rules for Contentrain — quality standards, architecture conventions, IDE integration",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Contentrain/ai.git",
    "directory": "packages/rules"
  },
  "homepage": "https://github.com/Contentrain/ai/tree/main/packages/rules",
  "bugs": {
    "url": "https://github.com/Contentrain/ai/issues"
  },
  "keywords": [
    "contentrain",
    "ai",
    "rules",
    "mcp",
    "prompt-engineering",
    "claude-code",
    "cursor",
    "windsurf"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./shared/*": "./shared/*",
    "./prompts/*": "./prompts/*",
    "./context/*": "./context/*",
    "./ide/*": "./ide/*"
  },
  "files": [
    "dist",
    "shared",
    "prompts",
    "context",
    "ide"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts && node --import tsx scripts/build-rules.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.21.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
