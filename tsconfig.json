{
  "compilerOptions": {
    "target": "ES2023",
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@contentrain/types": ["packages/types/src/index.ts"],
      "@contentrain/mcp": ["packages/mcp/src/index.ts"],
      "@contentrain/mcp/server": ["packages/mcp/src/server.ts"],
      "@contentrain/mcp/core/*": ["packages/mcp/src/core/*.ts", "packages/mcp/src/core/*/index.ts"],
      "@contentrain/mcp/util/*": ["packages/mcp/src/util/*.ts"],
      "@contentrain/mcp/git/*": ["packages/mcp/src/git/*.ts"],
      "@contentrain/mcp/templates": ["packages/mcp/src/templates/index.ts"],
      "@contentrain/query": ["packages/sdk/js/src/index.ts"],
      "@contentrain/query/generate": ["packages/sdk/js/src/generator/generate.ts"]
    },
    "lib": ["ES2023"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true
  },
  "exclude": ["node_modules", "dist", ".output", ".nuxt"]
}
