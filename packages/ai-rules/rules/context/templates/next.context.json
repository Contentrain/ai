{
  "version": 1,
  "project": {
    "name": "my-next-app",
    "description": "SaaS marketing site with documentation and blog",
    "stack": "next",
    "stack_version": "15.x",
    "package_manager": "npm",
    "src_dir": "src/",
    "content_consumption": "build-time"
  },
  "content": {
    "import_pattern": "import {model} from '@/.contentrain/content/{domain}/{model}/{locale}.json'",
    "i18n_strategy": "file-per-locale",
    "default_locale": "en",
    "supported_locales": ["en", "es", "fr"],
    "domains": [
      {
        "id": "marketing",
        "description": "Landing page content — hero, features, pricing, FAQ",
        "models": ["hero", "features", "pricing", "faq"]
      },
      {
        "id": "docs",
        "description": "Documentation pages and sidebar navigation",
        "models": ["doc-page", "doc-sidebar"]
      },
      {
        "id": "blog",
        "description": "Blog articles and tags",
        "models": ["blog-post", "tags"]
      }
    ]
  },
  "normalize": {
    "scan_dirs": ["src/components/", "src/app/"],
    "scan_extensions": [".tsx", ".ts", ".jsx"],
    "ignore_patterns": [".next/", "node_modules/", "out/", ".contentrain/", "*.test.*", "*.spec.*"],
    "import_rewrite": "import { useTranslations } from 'next-intl'"
  },
  "conventions": {
    "tone": "Professional, clear. Developer-friendly language.",
    "brand_terms": {
      "product_name": "My Next App",
      "company_name": "Acme Corp"
    },
    "forbidden_terms": ["click here", "lorem ipsum", "TODO", "TBD"],
    "max_title_length": 70,
    "max_description_length": 155,
    "target_reading_level": "grade-8",
    "allowed_richtext_tags": [
      "p", "strong", "em", "a", "ul", "ol", "li",
      "h2", "h3", "h4", "h5", "h6",
      "blockquote", "code", "pre", "img", "br", "hr",
      "table", "thead", "tbody", "tr", "th", "td",
      "del", "ins", "sup", "sub", "abbr", "mark",
      "details", "summary"
    ]
  },
  "lastOperation": {
    "tool": "model_save",
    "model": "blog-post",
    "locale": "en",
    "entries": [],
    "timestamp": "2026-03-10T16:45:00Z",
    "source": "mcp-local"
  },
  "stats": {
    "models": 7,
    "entries": 54,
    "locales": ["en", "es", "fr"],
    "lastSync": "2026-03-10T16:45:00Z"
  }
}
