{
  "name": "contentrain-ai",
  "private": true,
  "license": "MIT",
  "description": "AI-generated content governance infrastructure — Agent üretir, insan onaylar, sistem standardize eder.",
  "repository": {
    "type": "git",
    "url": "https://github.com/contentrain/contentrain-ai.git"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "test": "pnpm -r run test",
    "lint": "oxlint --deny-warnings .",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "release:version": "node scripts/version-packages.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:pack": "node scripts/release-pack.mjs",
    "release:bump": "node scripts/release-bump.mjs",
    "release": "node scripts/release-tag.mjs",
    "docs:dev": "pnpm --dir docs dev",
    "docs:build": "pnpm --dir docs build",
    "docs:preview": "pnpm --dir docs preview"
  },
  "devDependencies": {
    "lefthook": "^2.1.4",
    "oxlint": "^1.54.0",
    "vitest": "^3.0.0"
  },
  "imports": {
    "#contentrain": {
      "types": "./.contentrain/client/index.d.ts",
      "import": "./.contentrain/client/index.mjs",
      "require": "./.contentrain/client/index.cjs",
      "default": "./.contentrain/client/index.mjs"
    },
    "#contentrain/*": {
      "types": "./.contentrain/client/*.d.ts",
      "import": "./.contentrain/client/*.mjs",
      "require": "./.contentrain/client/*.cjs",
      "default": "./.contentrain/client/*.mjs"
    }
  }
}
