{
  "name": "@contentrain/mcp",
  "version": "1.2.0",
  "mcpName": "io.github.Contentrain/contentrain",
  "license": "MIT",
  "description": "Local-first MCP server for AI-generated content governance — 13 deterministic tools for any platform",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Contentrain/ai.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://ai.contentrain.io/packages/mcp",
  "bugs": {
    "url": "https://github.com/Contentrain/ai/issues"
  },
  "keywords": [
    "contentrain",
    "mcp",
    "model-context-protocol",
    "ai",
    "content-governance",
    "git",
    "i18n",
    "normalize",
    "local-first",
    "platform-independent",
    "claude",
    "cursor",
    "windsurf"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "contentrain-mcp": "./dist/index.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs"
    },
    "./core/config": {
      "types": "./dist/core/config.d.ts",
      "import": "./dist/core/config.mjs"
    },
    "./core/context": {
      "types": "./dist/core/context.d.ts",
      "import": "./dist/core/context.mjs"
    },
    "./core/model-manager": {
      "types": "./dist/core/model-manager.d.ts",
      "import": "./dist/core/model-manager.mjs"
    },
    "./core/content-manager": {
      "types": "./dist/core/content-manager.d.ts",
      "import": "./dist/core/content-manager.mjs"
    },
    "./core/validator": {
      "types": "./dist/core/validator/index.d.ts",
      "import": "./dist/core/validator/index.mjs"
    },
    "./core/scanner": {
      "types": "./dist/core/scanner.d.ts",
      "import": "./dist/core/scanner.mjs"
    },
    "./core/graph-builder": {
      "types": "./dist/core/graph-builder.d.ts",
      "import": "./dist/core/graph-builder.mjs"
    },
    "./core/apply-manager": {
      "types": "./dist/core/apply-manager.d.ts",
      "import": "./dist/core/apply-manager.mjs"
    },
    "./core/scan-config": {
      "types": "./dist/core/scan-config.d.ts",
      "import": "./dist/core/scan-config.mjs"
    },
    "./util/detect": {
      "types": "./dist/util/detect.d.ts",
      "import": "./dist/util/detect.mjs"
    },
    "./util/fs": {
      "types": "./dist/util/fs.d.ts",
      "import": "./dist/util/fs.mjs"
    },
    "./git/transaction": {
      "types": "./dist/git/transaction.d.ts",
      "import": "./dist/git/transaction.mjs"
    },
    "./git/branch-lifecycle": {
      "types": "./dist/git/branch-lifecycle.d.ts",
      "import": "./dist/git/branch-lifecycle.mjs"
    },
    "./templates": {
      "types": "./dist/templates/index.d.ts",
      "import": "./dist/templates/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts src/server.ts src/core/config.ts src/core/context.ts src/core/model-manager.ts src/core/content-manager.ts src/core/meta-manager.ts src/core/validator/index.ts src/core/scanner.ts src/core/scan-config.ts src/core/graph-builder.ts src/core/apply-manager.ts src/util/detect.ts src/util/fs.ts src/util/id.ts src/util/serializer.ts src/git/transaction.ts src/git/branch-lifecycle.ts src/templates/index.ts --format esm --dts --external typescript",
    "dev": "tsdown src/index.ts src/server.ts src/core/config.ts src/core/context.ts src/core/model-manager.ts src/core/content-manager.ts src/core/meta-manager.ts src/core/validator/index.ts src/core/scanner.ts src/core/scan-config.ts src/core/graph-builder.ts src/core/apply-manager.ts src/util/detect.ts src/util/fs.ts src/util/id.ts src/util/serializer.ts src/git/transaction.ts src/git/branch-lifecycle.ts src/templates/index.ts --format esm --dts --external typescript --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@contentrain/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "simple-git": "^3.27.0",
    "typescript": "^5.7.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "@astrojs/compiler": "^2.10.0",
    "@vue/compiler-sfc": "^3.5.30",
    "svelte": "^4.2.0"
  },
  "devDependencies": {
    "@astrojs/compiler": "^2.10.0",
    "@types/node": "^25.4.0",
    "@vue/compiler-sfc": "^3.5.30",
    "svelte": "^4.2.0",
    "tsdown": "^0.21.0",
    "vitest": "^3.0.0"
  }
}
