{
  "name": "@contentrain/ai-rules",
  "version": "0.0.0",
  "license": "MIT",
  "description": "AI agent rules and prompts for Contentrain IDE integration",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./rules/*": "./rules/*",
    "./skills/*": "./skills/*",
    "./prompts/*": "./prompts/*",
    "./frameworks/*": "./frameworks/*",
    "./context/*": "./context/*"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist", "rules", "skills", "prompts", "frameworks", "context"],
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts",
    "dev": "tsdown src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@contentrain/types": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "^0.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
