{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxc-config-schema/refs/heads/main/oxlintrc.schema.json",
  "rules": {
    "no-await-in-loop": "off",
    "unicorn/prefer-set-has": "off"
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    ".output",
    ".nuxt",
    "docs/.vitepress/cache",
    "docs/.vitepress/dist",
    "coverage",
    "pnpm-lock.yaml",
    ".contentrain/client"
  ]
}
