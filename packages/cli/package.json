{
  "name": "contentrain",
  "version": "0.0.0",
  "license": "MIT",
  "description": "CLI for Contentrain — AI content governance infrastructure",
  "type": "module",
  "bin": {
    "contentrain": "./dist/index.mjs"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown src/index.ts --format esm",
    "dev": "tsdown src/index.ts --format esm --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@contentrain/mcp": "workspace:*",
    "@contentrain/query": "workspace:*",
    "@contentrain/types": "workspace:*",
    "@clack/prompts": "^0.10.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "citty": "^0.1.0",
    "consola": "^3.4.0",
    "picocolors": "^1.1.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
