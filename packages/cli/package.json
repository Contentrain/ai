{
  "name": "contentrain",
  "version": "0.1.2",
  "license": "MIT",
  "description": "CLI for Contentrain — AI content governance infrastructure",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Contentrain/ai.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Contentrain/ai/tree/main/packages/cli",
  "bugs": {
    "url": "https://github.com/Contentrain/ai/issues"
  },
  "keywords": [
    "contentrain",
    "cli",
    "mcp",
    "content-governance",
    "ai",
    "i18n",
    "cms"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "contentrain": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format esm && cd src/serve-ui && npx vite build",
    "build:cli-only": "tsdown src/index.ts --format esm",
    "build:ui-only": "cd src/serve-ui && npx vite build",
    "dev": "tsdown src/index.ts --format esm --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@contentrain/rules": "workspace:*",
    "@contentrain/mcp": "workspace:*",
    "@contentrain/query": "workspace:*",
    "@contentrain/types": "workspace:*",
    "@clack/prompts": "^0.10.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chokidar": "^4.0.0",
    "citty": "^0.1.0",
    "consola": "^3.4.0",
    "crossws": "^0.3.0",
    "h3": "^1.15.0",
    "picocolors": "^1.1.0",
    "simple-git": "^3.27.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "@types/node": "^22.0.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
