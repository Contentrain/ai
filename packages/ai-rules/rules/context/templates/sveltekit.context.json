{
  "version": 1,
  "project": {
    "name": "my-sveltekit-app",
    "description": "Community platform with blog and user-generated content",
    "stack": "sveltekit",
    "stack_version": "2.x",
    "package_manager": "pnpm",
    "src_dir": "src/",
    "content_consumption": "build-time"
  },
  "content": {
    "import_pattern": "import {model} from '$lib/.contentrain/content/{domain}/{model}/{locale}.json'",
    "i18n_strategy": "file-per-locale",
    "default_locale": "en",
    "supported_locales": ["en", "ja"],
    "domains": [
      {
        "id": "marketing",
        "description": "Landing page content — hero, features, pricing",
        "models": ["hero", "features", "pricing"]
      },
      {
        "id": "blog",
        "description": "Blog posts and tags",
        "models": ["blog-post", "tags"]
      },
      {
        "id": "ui",
        "description": "UI strings — navigation, footer, form labels",
        "models": ["navigation", "footer", "form-labels"]
      }
    ]
  },
  "normalize": {
    "scan_dirs": ["src/lib/", "src/routes/"],
    "scan_extensions": [".svelte", ".ts"],
    "ignore_patterns": [".svelte-kit/", "node_modules/", "build/", ".contentrain/", "*.test.*", "*.spec.*"],
    "import_rewrite": "import { t } from '$lib/i18n'"
  },
  "conventions": {
    "tone": "Casual, developer-friendly. Clear and direct.",
    "brand_terms": {
      "product_name": "My SvelteKit App",
      "company_name": "Svelte Works"
    },
    "forbidden_terms": ["click here", "lorem ipsum", "TODO"],
    "max_title_length": 80,
    "max_description_length": 160,
    "target_reading_level": "grade-8",
    "allowed_richtext_tags": [
      "p", "strong", "em", "a", "ul", "ol", "li",
      "h2", "h3", "h4", "h5", "h6",
      "blockquote", "code", "pre", "img", "br", "hr",
      "table", "thead", "tbody", "tr", "th", "td",
      "del", "ins", "sup", "sub", "abbr", "mark",
      "details", "summary"
    ]
  },
  "lastOperation": {
    "tool": "scaffold",
    "model": "blog-post",
    "locale": "en",
    "entries": ["b2c3d4e5f6a7"],
